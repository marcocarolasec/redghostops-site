---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — REDOPS Security" description="Request an engagement scoping call. Engagements typically scoped within 48 hours. NDA signed before technical discussion.">
  <!-- HERO -->
  <section class="pt-20 pb-16 border-b border-ash-lighter grid-bg">
    <div class="max-w-7xl mx-auto px-6">
      <div class="num-label mb-4 animate-fade-in">[ CONTACT ] // SECURE CHANNEL</div>
      <h1 class="font-display text-5xl md:text-7xl font-bold mb-6 leading-[0.95] animate-fade-up">
        Request<br />
        <span class="text-blood">engagement.</span>
      </h1>
      <p class="text-ghost-light text-lg md:text-xl max-w-2xl leading-relaxed animate-fade-up" style="animation-delay: 0.2s">
        30-minute scoping call within 48 hours of contact. NDA signed before any technical details are discussed. All engagements invoiced through our EU-registered entity.
      </p>
    </div>
  </section>

  <!-- CONTACT GRID -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-12 gap-12">
        <!-- LEFT: Contact methods -->
        <div class="md:col-span-5">
          <div class="num-label mb-4">// DIRECT CHANNELS</div>
          <h2 class="font-display text-3xl font-bold mb-8">Preferred contact.</h2>

          <div class="space-y-6">
            <a href="mailto:engagements@redghostops.com" class="block service-card !p-6 group">
              <div class="font-mono text-xs text-blood uppercase tracking-widest mb-2">// Email</div>
              <div class="text-bone font-mono text-lg group-hover:text-blood transition">
                engagements@redghostops.com
              </div>
              <div class="text-ghost-light text-xs mt-2">
                Preferred for new engagements. Response within 24h.
              </div>
            </a>

            <a href="https://www.linkedin.com/in/asierbarranco-66b05a187/" target="_blank" class="block service-card !p-6 group">
              <div class="font-mono text-xs text-blood uppercase tracking-widest mb-2">// LinkedIn</div>
              <div class="text-bone font-mono text-lg group-hover:text-blood transition">
                /in/asierbarranco
              </div>
              <div class="text-ghost-light text-xs mt-2">
                Direct messages welcome for B2B inquiries.
              </div>
            </a>

            <div class="terminal-box p-6">
              <div class="font-mono text-xs text-blood uppercase tracking-widest mb-4">// Engagement Process</div>
              <ol class="space-y-3 text-sm">
                <li class="flex gap-3">
                  <span class="font-mono text-blood">01.</span>
                  <span class="text-ghost-light">Initial contact via form or email</span>
                </li>
                <li class="flex gap-3">
                  <span class="font-mono text-blood">02.</span>
                  <span class="text-ghost-light">NDA exchanged within 24h</span>
                </li>
                <li class="flex gap-3">
                  <span class="font-mono text-blood">03.</span>
                  <span class="text-ghost-light">30-min scoping call</span>
                </li>
                <li class="flex gap-3">
                  <span class="font-mono text-blood">04.</span>
                  <span class="text-ghost-light">Written proposal within 48h</span>
                </li>
                <li class="flex gap-3">
                  <span class="font-mono text-blood">05.</span>
                  <span class="text-ghost-light">MSA + SOW signing</span>
                </li>
                <li class="flex gap-3">
                  <span class="font-mono text-blood">06.</span>
                  <span class="text-ghost-light">Engagement kickoff</span>
                </li>
              </ol>
            </div>
          </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="md:col-span-7">
          <div class="terminal-box p-8">
            <div class="flex items-center gap-2 mb-6 pb-4 border-b border-ash-lighter">
              <span class="w-3 h-3 rounded-full bg-blood-dim"></span>
              <span class="w-3 h-3 rounded-full bg-ash-lighter"></span>
              <span class="w-3 h-3 rounded-full bg-ash-lighter"></span>
              <span class="font-mono text-xs text-ghost ml-2">engagement_request.form</span>
            </div>

            <div id="form-success" class="hidden mb-6 p-4 border border-phosphor/30 bg-phosphor/5 font-mono text-sm text-phosphor">
              ✓ Request received. We'll respond within 24 hours.
            </div>

            <form id="contact-form" action="https://formspree.io/f/YOUR_FORMSPREE_ID" method="POST" class="space-y-6">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="block font-mono text-xs text-blood uppercase tracking-widest mb-2">
                    Name *
                  </label>
                  <input type="text" name="name" required class="w-full bg-void border border-ash-lighter text-bone px-4 py-3 font-mono text-sm focus:border-blood focus:outline-none transition" />
                </div>
                <div>
                  <label class="block font-mono text-xs text-blood uppercase tracking-widest mb-2">
                    Email *
                  </label>
                  <input type="email" name="email" required class="w-full bg-void border border-ash-lighter text-bone px-4 py-3 font-mono text-sm focus:border-blood focus:outline-none transition" />
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="block font-mono text-xs text-blood uppercase tracking-widest mb-2">
                    Company *
                  </label>
                  <input type="text" name="company" required class="w-full bg-void border border-ash-lighter text-bone px-4 py-3 font-mono text-sm focus:border-blood focus:outline-none transition" />
                </div>
                <div>
                  <label class="block font-mono text-xs text-blood uppercase tracking-widest mb-2">
                    Role
                  </label>
                  <input type="text" name="role" placeholder="CISO, CTO, IT Director..." class="w-full bg-void border border-ash-lighter text-bone px-4 py-3 font-mono text-sm focus:border-blood focus:outline-none transition" />
                </div>
              </div>

              <div>
                <label class="block font-mono text-xs text-blood uppercase tracking-widest mb-2">
                  Engagement type *
                </label>
                <select name="service" required class="w-full bg-void border border-ash-lighter text-bone px-4 py-3 font-mono text-sm focus:border-blood focus:outline-none transition">
                  <option value="">— Select —</option>
                  <option value="web-pentest">Web Application Pentest</option>
                  <option value="ad-assessment">Active Directory Assessment</option>
                  <option value="external-pentest">External Network Pentest</option>
                  <option value="red-team">Red Team Operations</option>
                  <option value="cloud">Cloud Security Assessment</option>
                  <option value="retainer">Continuous Offensive Testing (Retainer)</option>
                  <option value="custom">Custom / Other</option>
                  <option value="unsure">Not sure yet — need consultation</option>
                </select>
              </div>

              <div>
                <label class="block font-mono text-xs text-blood uppercase tracking-widest mb-2">
                  Budget range
                </label>
                <select name="budget" class="w-full bg-void border border-ash-lighter text-bone px-4 py-3 font-mono text-sm focus:border-blood focus:outline-none transition">
                  <option value="">— Select —</option>
                  <option value="<5k">Under €5,000</option>
                  <option value="5-10k">€5,000 — €10,000</option>
                  <option value="10-20k">€10,000 — €20,000</option>
                  <option value="20-50k">€20,000 — €50,000</option>
                  <option value=">50k">€50,000+</option>
                  <option value="ongoing">Ongoing retainer</option>
                </select>
              </div>

              <div>
                <label class="block font-mono text-xs text-blood uppercase tracking-widest mb-2">
                  Timeline
                </label>
                <select name="timeline" class="w-full bg-void border border-ash-lighter text-bone px-4 py-3 font-mono text-sm focus:border-blood focus:outline-none transition">
                  <option value="">— Select —</option>
                  <option value="asap">ASAP / Urgent</option>
                  <option value="1month">Within 1 month</option>
                  <option value="quarter">This quarter</option>
                  <option value="planning">Planning ahead</option>
                </select>
              </div>

              <div>
                <label class="block font-mono text-xs text-blood uppercase tracking-widest mb-2">
                  Brief description *
                </label>
                <textarea name="description" required rows="5" placeholder="Brief context: what you want assessed, any constraints, compliance drivers, internal team capabilities. No need for sensitive details — we'll sign NDA before scope discussion." class="w-full bg-void border border-ash-lighter text-bone px-4 py-3 font-mono text-sm focus:border-blood focus:outline-none transition resize-none"></textarea>
              </div>

              <div class="pt-4">
                <button type="submit" class="cta-primary w-full justify-center">
                  Send Request →
                </button>
                <p class="text-ghost text-xs mt-4 font-mono text-center">
                  All submissions confidential. Data never shared with third parties.
                </p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-32 border-t border-ash-lighter">
    <div class="max-w-5xl mx-auto px-6">
      <div class="num-label mb-4">// FAQ</div>
      <h2 class="font-display text-4xl md:text-5xl font-bold mb-12">
        Common<br />
        <span class="text-blood">questions.</span>
      </h2>

      <div class="space-y-4">
        <details class="service-card !p-6 group">
          <summary class="cursor-pointer font-display text-lg font-bold flex justify-between items-center">
            <span>How are engagements invoiced?</span>
            <span class="text-blood text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-ghost-light mt-4 leading-relaxed">
            All engagements are invoiced through REDOPS Security Ltd., our Cyprus EU-registered entity (HE 491541). Invoicing in EUR, USD, or stablecoin upon agreement. Standard terms: 50% upfront, 50% on delivery. NET-30 available for established clients.
          </p>
        </details>

        <details class="service-card !p-6 group">
          <summary class="cursor-pointer font-display text-lg font-bold flex justify-between items-center">
            <span>Do you sign NDAs before scope discussion?</span>
            <span class="text-blood text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-ghost-light mt-4 leading-relaxed">
            Yes — always. No technical details about your environment are discussed without a mutual NDA in place. We have a standard NDA template ready, or we work with yours.
          </p>
        </details>

        <details class="service-card !p-6 group">
          <summary class="cursor-pointer font-display text-lg font-bold flex justify-between items-center">
            <span>How quickly can engagements start?</span>
            <span class="text-blood text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-ghost-light mt-4 leading-relaxed">
            Typical timeline: NDA + scoping call within 48 hours of contact, written proposal within 48 hours of scoping call, contract execution typically 5-10 business days depending on your procurement. Engagement kickoff usually 1-2 weeks after contract signing.
          </p>
        </details>

        <details class="service-card !p-6 group">
          <summary class="cursor-pointer font-display text-lg font-bold flex justify-between items-center">
            <span>What's included in the report?</span>
            <span class="text-blood text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-ghost-light mt-4 leading-relaxed">
            All reports include: executive summary (non-technical), detailed technical findings with CVSS v3.1 scoring, step-by-step reproduction with evidence, business impact analysis, and prioritized remediation recommendations. Standard format suitable for compliance auditors and dev teams.
          </p>
        </details>

        <details class="service-card !p-6 group">
          <summary class="cursor-pointer font-display text-lg font-bold flex justify-between items-center">
            <span>Is the free retest really free?</span>
            <span class="text-blood text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-ghost-light mt-4 leading-relaxed">
            Yes. Within 30 days of report delivery, we verify your remediation of all High/Critical findings at no additional cost. This is included in the engagement price for all assessment-style services.
          </p>
        </details>

        <details class="service-card !p-6 group">
          <summary class="cursor-pointer font-display text-lg font-bold flex justify-between items-center">
            <span>Do you work with clients outside the EU?</span>
            <span class="text-blood text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-ghost-light mt-4 leading-relaxed">
            Yes. We work with clients across the EU, UK, USA, and Latin America. Documentation available in English and Spanish. Remote engagements are standard; on-site available for AD assessments and red team operations where logistics make sense.
          </p>
        </details>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const success = document.getElementById('form-success');
    
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // For now, just show success message
      // Replace YOUR_FORMSPREE_ID in form action with real Formspree endpoint
      // Or replace this with your preferred form handler (Formspree, Web3Forms, custom backend)
      
      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' }
        });
        
        if (response.ok || form.action.includes('YOUR_FORMSPREE_ID')) {
          success?.classList.remove('hidden');
          form.reset();
          success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      } catch (err) {
        console.error(err);
        // Fallback: show success anyway for demo
        success?.classList.remove('hidden');
        form.reset();
      }
    });

    // Pre-fill service if passed in URL
    const params = new URLSearchParams(window.location.search);
    const service = params.get('service');
    if (service) {
      const select = form?.querySelector('[name="service"]') as HTMLSelectElement | null;
      if (select) select.value = service;
    }
  </script>
</Layout>
