---
import Layout from '../layouts/Layout.astro';

const CALENDLY_URL = 'https://calendly.com/asbarraninfor/redghostops-onboarding';
---

<Layout title="Book a Call — REDOPS Security" description="Book a 30-minute scoping call directly. Mutual NDA signed within 24h. All engagements invoiced through our EU-registered entity.">
  <!-- HERO -->
  <section class="pt-20 pb-16 border-b border-ash-lighter grid-bg">
    <div class="max-w-7xl mx-auto px-6">
      <div class="num-label mb-4 animate-fade-in">[ CONTACT ] // SECURE CHANNEL</div>
      <h1 class="font-display text-5xl md:text-7xl font-bold mb-6 leading-[0.95] animate-fade-up">
        Book a<br />
        <span class="text-blood">scoping call.</span>
      </h1>
      <p class="text-ghost-light text-lg md:text-xl max-w-2xl leading-relaxed animate-fade-up" style="animation-delay: 0.2s">
        Pick a 30-minute slot directly in the calendar below. Mutual NDA exchanged in the 24 hours before the call. No technical details discussed before the NDA is in place.
      </p>
    </div>
  </section>

  <!-- BOOKING GRID -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-8">
        <!-- LEFT: Context column -->
        <aside class="lg:col-span-4 space-y-6">
          <div>
            <div class="num-label mb-4">// HOW IT WORKS</div>
            <div class="terminal-box p-6">
              <div class="flex items-center gap-2 mb-4 pb-4 border-b border-ash-lighter">
                <span class="w-3 h-3 rounded-full bg-blood-dim"></span>
                <span class="w-3 h-3 rounded-full bg-ash-lighter"></span>
                <span class="w-3 h-3 rounded-full bg-ash-lighter"></span>
                <span class="font-mono text-xs text-ghost ml-2">engagement.flow</span>
              </div>
              <ol class="space-y-3 text-sm">
                <li class="flex gap-3">
                  <span class="font-mono text-blood">01.</span>
                  <span class="text-ghost-light">Pick a slot in the calendar</span>
                </li>
                <li class="flex gap-3">
                  <span class="font-mono text-blood">02.</span>
                  <span class="text-ghost-light">Mutual NDA exchanged within 24h</span>
                </li>
                <li class="flex gap-3">
                  <span class="font-mono text-blood">03.</span>
                  <span class="text-ghost-light">30-min discovery call (Zoom / Meet / Teams)</span>
                </li>
                <li class="flex gap-3">
                  <span class="font-mono text-blood">04.</span>
                  <span class="text-ghost-light">Written proposal within 48h</span>
                </li>
                <li class="flex gap-3">
                  <span class="font-mono text-blood">05.</span>
                  <span class="text-ghost-light">MSA + SOW signing</span>
                </li>
                <li class="flex gap-3">
                  <span class="font-mono text-blood">06.</span>
                  <span class="text-ghost-light">Engagement kickoff</span>
                </li>
              </ol>
            </div>
          </div>

          <div>
            <div class="num-label mb-4">// CAN'T USE THE CALENDAR?</div>
            <div class="space-y-3">
              <a href="mailto:engagements@redghostops.com?subject=Scoping%20call%20request" class="block service-card !p-5 group">
                <div class="font-mono text-xs text-blood uppercase tracking-widest mb-1">// Email</div>
                <div class="text-bone font-mono text-sm group-hover:text-blood transition break-all">
                  engagements@redghostops.com
                </div>
                <div class="text-ghost-light text-xs mt-2">
                  Reply within 24h. Preferred if you need procurement sign-off first.
                </div>
              </a>

              <a href="https://www.linkedin.com/in/asierbarranco-66b05a187/" target="_blank" rel="noopener" class="block service-card !p-5 group">
                <div class="font-mono text-xs text-blood uppercase tracking-widest mb-1">// LinkedIn</div>
                <div class="text-bone font-mono text-sm group-hover:text-blood transition">
                  /in/asierbarranco
                </div>
                <div class="text-ghost-light text-xs mt-2">
                  Direct messages welcome for B2B inquiries.
                </div>
              </a>
            </div>
          </div>

          <div class="border-l border-blood pl-4">
            <div class="font-mono text-xs text-blood uppercase tracking-widest mb-2">// Privacy</div>
            <p class="text-ghost-light text-xs leading-relaxed">
              Bookings handled via Calendly (GDPR-compliant). No technical scope discussed before mutual NDA. Data never shared with third parties.
            </p>
          </div>
        </aside>

        <!-- RIGHT: Calendar CTA card -->
        <div class="lg:col-span-8">
          <div class="terminal-box overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-ash-lighter">
              <span class="w-3 h-3 rounded-full bg-blood-dim"></span>
              <span class="w-3 h-3 rounded-full bg-ash-lighter"></span>
              <span class="w-3 h-3 rounded-full bg-ash-lighter"></span>
              <span class="font-mono text-xs text-ghost ml-2">scoping_call.book</span>
              <span class="ml-auto font-mono text-[0.65rem] text-phosphor tracking-widest uppercase flex items-center gap-2">
                <span class="w-1.5 h-1.5 bg-phosphor rounded-full animate-pulse"></span>
                Live
              </span>
            </div>

            <div id="service-context" class="hidden mx-6 mt-6 p-3 border border-blood/30 bg-blood/5 font-mono text-xs text-blood">
              Service of interest: <span id="service-label" class="text-bone font-bold"></span> — mention any specifics in the booking notes.
            </div>

            <div class="px-6 sm:px-10 py-12 sm:py-16">
              <!-- Calendar icon -->
              <div class="flex justify-center mb-8">
                <div class="relative w-20 h-20 border border-blood-dim flex items-center justify-center">
                  <div class="absolute -top-px left-3 right-3 h-px bg-blood"></div>
                  <div class="absolute -top-2 left-3 w-px h-3 bg-blood"></div>
                  <div class="absolute -top-2 right-3 w-px h-3 bg-blood"></div>
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-blood">
                    <rect x="3" y="5" width="18" height="16" rx="0"></rect>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                    <line x1="8" y1="3" x2="8" y2="7"></line>
                    <line x1="16" y1="3" x2="16" y2="7"></line>
                  </svg>
                </div>
              </div>

              <!-- Headline -->
              <h2 class="font-display text-3xl md:text-4xl font-bold text-center text-bone leading-tight mb-3">
                Book a 30-min<br /><span class="text-blood">scoping call.</span>
              </h2>
              <p class="text-ghost-light text-center text-sm max-w-md mx-auto mb-10 leading-relaxed">
                Live availability on Calendly. Pick a slot, get a calendar invite, mutual NDA arrives in your inbox before the call.
              </p>

              <!-- Primary CTA -->
              <div class="flex justify-center mb-8">
                <a
                  id="calendly-link"
                  href={CALENDLY_URL}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="cta-primary text-base !py-4 !px-8"
                >
                  Open Calendar
                  <span>→</span>
                </a>
              </div>

              <!-- URL preview + meta -->
              <div class="max-w-md mx-auto space-y-3">
                <div class="font-mono text-[0.65rem] text-ghost uppercase tracking-widest text-center">
                  // Booking endpoint
                </div>
                <div class="border border-ash-lighter bg-void/50 px-4 py-3 font-mono text-xs text-ghost-light text-center break-all">
                  <span class="text-blood">$</span> open <span class="text-bone">calendly.com/asbarraninfor/redghostops-onboarding</span>
                </div>
                <div class="flex justify-between items-center font-mono text-[0.65rem] text-ghost uppercase tracking-widest pt-2">
                  <span class="flex items-center gap-2">
                    <span class="w-1 h-1 bg-phosphor rounded-full"></span>
                    Opens in new tab
                  </span>
                  <span>~30s to book</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-32 border-t border-ash-lighter">
    <div class="max-w-5xl mx-auto px-6">
      <div class="num-label mb-4">// FAQ</div>
      <h2 class="font-display text-4xl md:text-5xl font-bold mb-12">
        Common<br />
        <span class="text-blood">questions.</span>
      </h2>

      <div class="space-y-4">
        <details class="service-card !p-6 group">
          <summary class="cursor-pointer font-display text-lg font-bold flex justify-between items-center">
            <span>How quickly can engagements start?</span>
            <span class="text-blood text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-ghost-light mt-4 leading-relaxed">
            You book a slot directly in the calendar — earliest availability is usually same week. NDA exchanged in the 24h before the call. Written proposal within 48h of the call. Contract execution typically 5-10 business days depending on your procurement. Engagement kickoff usually 1-2 weeks after contract signing.
          </p>
        </details>

        <details class="service-card !p-6 group">
          <summary class="cursor-pointer font-display text-lg font-bold flex justify-between items-center">
            <span>Do you sign NDAs before scope discussion?</span>
            <span class="text-blood text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-ghost-light mt-4 leading-relaxed">
            Yes — always. No technical details about your environment are discussed without a mutual NDA in place. We have a standard NDA template ready, or we work with yours.
          </p>
        </details>

        <details class="service-card !p-6 group">
          <summary class="cursor-pointer font-display text-lg font-bold flex justify-between items-center">
            <span>How are engagements invoiced?</span>
            <span class="text-blood text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-ghost-light mt-4 leading-relaxed">
            All engagements are invoiced through REDOPS Security Ltd., our Cyprus EU-registered entity (HE 491541). Invoicing in EUR, USD, or stablecoin upon agreement. Standard terms: 50% upfront, 50% on delivery. NET-30 available for established clients.
          </p>
        </details>

        <details class="service-card !p-6 group">
          <summary class="cursor-pointer font-display text-lg font-bold flex justify-between items-center">
            <span>What's included in the report?</span>
            <span class="text-blood text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-ghost-light mt-4 leading-relaxed">
            All reports include: executive summary (non-technical), detailed technical findings with CVSS v3.1 scoring, step-by-step reproduction with evidence, business impact analysis, and prioritized remediation recommendations. Standard format suitable for compliance auditors and dev teams.
          </p>
        </details>

        <details class="service-card !p-6 group">
          <summary class="cursor-pointer font-display text-lg font-bold flex justify-between items-center">
            <span>Is the free retest really free?</span>
            <span class="text-blood text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-ghost-light mt-4 leading-relaxed">
            Yes. Within 30 days of report delivery, we verify your remediation of all High/Critical findings at no additional cost. This is included in the engagement price for all assessment-style services.
          </p>
        </details>

        <details class="service-card !p-6 group">
          <summary class="cursor-pointer font-display text-lg font-bold flex justify-between items-center">
            <span>Do you work with clients outside the EU?</span>
            <span class="text-blood text-2xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <p class="text-ghost-light mt-4 leading-relaxed">
            Yes. We work with clients across the EU, UK, USA, and Latin America. Documentation available in English and Spanish. Remote engagements are standard; on-site available for AD assessments and red team operations where logistics make sense.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Service prefill: badge + appends ?utm_content=<service> to Calendly URL -->
  <script is:inline>
    (function () {
      const params = new URLSearchParams(window.location.search);
      const service = params.get('service');
      if (!service) return;
      const labels = {
        'web-pentest': 'Web Application Pentest',
        'ad-assessment': 'Active Directory Assessment',
        'external-pentest': 'External Network Pentest',
        'red-team': 'Red Team Operations',
        'cloud': 'Cloud Security Assessment',
        'retainer': 'Continuous Offensive Testing',
        'custom': 'Custom engagement',
        'unsure': 'Consultation',
      };
      const labelEl = document.getElementById('service-label');
      const ctxEl = document.getElementById('service-context');
      if (labelEl && ctxEl) {
        labelEl.textContent = labels[service] || service;
        ctxEl.classList.remove('hidden');
      }
      const link = document.getElementById('calendly-link');
      if (link) {
        const url = new URL(link.href);
        url.searchParams.set('utm_content', service);
        link.href = url.toString();
      }
    })();
  </script>
</Layout>
